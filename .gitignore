# ================================
# ROOT-LEVEL .gitignore
# ================================

# Dependencies (both frontend & backend)
**/node_modules/

# Environment variables (NEVER push secrets)
**/.env
**/.env.local
**/.env.*.local

# Build outputs
**/dist/
**/build/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
**/logs/

# Uploaded files (user data, not source code)
**/uploads/

# Generated files
**/generated/

# Debug / temporary
debug_*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Prisma local DB files
**/*.db
**/*.db-journal

# Test coverage
**/coverage/
**/.nyc_output/

# Misc
*.tgz
*.tar.gz
